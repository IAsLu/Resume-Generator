
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<body>
    <div class="our">
        <h2>Welcome, @Session["Name"]!</h2>

        <p style="text-align:center">Here you can create new resumes for users. Implement the form and backend logic as needed.</p>


        <hr>

        <div class="features">
            <h3>Features</h3>
            <ul>
                <li>Easy to use resume builder</li>
                <li>Customizable templates</li>
                <li>Preview before downloading</li>
                <li>Save and edit resumes anytime</li>
                <li>Download in multiple formats</li>
            </ul>
        </div>

        <hr>

        <div class="cta">
            <h3>Get Started</h3>
        </div>
    </div>


</body>

<style>
    body {
        background-image: url("https://blog.depositphotos.com/wp-content/uploads/2017/07/Floral-patterns-1.jpg.webp");
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        background-position: center;
        font-family: Arial, sans-serif;
    }

    h2 {
        margin-top: 40px;
        text-align: center;
    }

    .our {
        width: 75%;
        margin: 40px auto;
        background-color: rgba(255, 255, 255, 0.8);
        padding: 50px;
        border-radius: 10px;
    }

    .features {
        margin-top: 20px;
    }

        .features ul {
            list-style-type: disc;
            padding-left: 20px;
        }

    .cta {
        margin-top: 30px;
        text-align: center;
    }

        .cta button {
            background-color: #4CAF50;
            color: white;
            padding: 15px 25px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }

            .cta button:hover {
                background-color: #45a049;
            }
</style>


