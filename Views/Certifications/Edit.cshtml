@model FINAL.Models.Template_2.Certifications

@{
    ViewBag.Title = "Edit Certification";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    body {
        background-image: url('https://img.pikbest.com/wp/202344/white-seamless-texture-soft-mink-cotton-wool-background_9929452.jpg!sw800');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    h2 {
        margin-bottom: 30px; /* Spacing below the heading */
        color: #333;
    }

    .form-group {
        margin-bottom: 20px; /* Spacing between form fields */
    }

    label {
        font-weight: bold;
    }

    .form-control {
        border-radius: 5px; /* Rounded corners for input fields */
    }

    .form-actions {
        margin-top: 20px;
    }
</style>

<h2 style="margin-top:7px;">Edit Certification</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.CertificationId)

    <div class="form-group">
        @Html.LabelFor(model => model.CertificationName)
        @Html.TextBoxFor(model => model.CertificationName, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.IssuingOrganization)
        @Html.TextBoxFor(model => model.IssuingOrganization, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Years)
        @Html.TextBoxFor(model => model.Years, new { @class = "form-control" })
    </div>

    @Html.HiddenFor(model => model.ResumeId)

    <div class="form-actions">
        <button type="button" onclick="history.back()" class="btn btn-secondary">Back</button>
        <button type="submit" class="btn btn-primary">Next</button>
    </div>
}
