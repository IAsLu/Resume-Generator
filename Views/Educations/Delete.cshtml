@model FINAL.Models.Template_2.Educations

@{
    ViewBag.Title = "Delete Education";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Delete Education</h2>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Education</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Degree</dt>
        <dd>@Html.DisplayFor(model => model.Degree)</dd>

        <dt>Major</dt>
        <dd>@Html.DisplayFor(model => model.Major)</dd>

        <dt>School Name</dt>
        <dd>@Html.DisplayFor(model => model.SchoolName)</dd>

        <dt>City</dt>
        <dd>@Html.DisplayFor(model => model.City)</dd>

        <dt>State</dt>
        <dd>@Html.DisplayFor(model => model.State)</dd>

        <dt>Graduation Year</dt>
        <dd>@Html.DisplayFor(model => model.GraduationYear)</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button> 
@Html.ActionLink("Cancel", "Index", new { resumeId = Model.ResumeId })
    }
</div>
