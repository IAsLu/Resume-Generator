@model FINAL.Models.Template_2.Educations

@{
    ViewBag.Title = "Education Details";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Education Details</h2>

<div>
    <h4>Education</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Degree</dt>
        <dd>@Html.DisplayFor(model => model.Degree)</dd>

        <dt>Major</dt>
        <dd>@Html.DisplayFor(model => model.Major)</dd>

        <dt>School Name</dt>
        <dd>@Html.DisplayFor(model => model.SchoolName)</dd>

        <dt>City</dt>
        <dd>@Html.DisplayFor(model => model.City)</dd>

        <dt>State</dt>
        <dd>@Html.DisplayFor(model => model.State)</dd>

        <dt>Graduation Year</dt>
        <dd>@Html.DisplayFor(model => model.GraduationYear)</dd>
    </dl>
</div>
<div>
    @Html.ActionLink("Edit", "Edit", new { id = Model.EducationId }) |
    @Html.ActionLink("Back to List", "Index", new { resumeId = Model.ResumeId })
</div>
