@model FINAL.Models.Template_2.Educations

@{
    ViewBag.Title = "Edit Education";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    body {
        background-image: url('https://img.pikbest.com/wp/202344/white-seamless-texture-soft-mink-cotton-wool-background_9929452.jpg!sw800');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    h2 {
            
        margin-bottom: 30px; /* Add spacing below the heading */
        color: #333;
    }

    .form-group {
        margin-bottom: 20px; /* Add spacing between form fields */
    }

    label {
        font-weight: bold;
    }

    .form-control {
        border-radius: 5px; /* Slightly rounded corners */
    }

   
</style>

<h2 style="margin-top:7px;">Edit Education</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(model => model.EducationId)
    @Html.HiddenFor(model => model.ResumeId)

    <div class="form-group">
        @Html.LabelFor(model => model.Degree)
        @Html.TextBoxFor(model => model.Degree, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.Degree)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Major)
        @Html.TextBoxFor(model => model.Major, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.Major)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.SchoolName)
        @Html.TextBoxFor(model => model.SchoolName, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.SchoolName)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.City)
        @Html.TextBoxFor(model => model.City, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.City)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.State)
        @Html.TextBoxFor(model => model.State, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.State)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.GraduationYear)
        @Html.TextBoxFor(model => model.GraduationYear, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.GraduationYear)
    </div>

    <div class="form-actions">
        <button type="button" onclick="history.back()" class="btn btn-secondary">Back</button>
        <button type="submit" class="btn btn-primary">Next</button>
    </div>
}
