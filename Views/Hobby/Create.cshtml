@model FINAL.Models.Template_2.Hobbies

@{
    ViewBag.Title = "Create Hobby";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    body {
        background-image: url('https://img.pikbest.com/wp/202344/white-seamless-texture-soft-mink-cotton-wool-background_9929452.jpg!sw800');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        background-attachment: fixed;
    }
</style>

<h2 style="margin-top:10px;">Hobby</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(model => model.HobbyName)
        @Html.TextBoxFor(model => model.HobbyName, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.HobbyName)
    </div>

    @Html.HiddenFor(model => model.ResumeId)

<div class="form-group" style="margin-top:20px">
    <div class="col-md-offset-2 col-md-10">
        <button type="button" onclick="history.back()" class="btn btn-secondary">Back</button>
        <button type="submit" class="btn btn-primary">Generate</button>
    </div>
</div>
}
