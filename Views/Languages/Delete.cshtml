@model FINAL.Models.Template_2.Languages

@{
    ViewBag.Title = "Delete Language";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Delete Language</h2>

<h3>Are you sure you want to delete this language?</h3>

<div>
    <h4>@Model.LanguageName</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.LanguageName)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.LanguageName)
        </dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.LanguageId)
        @Html.HiddenFor(model => model.ResumeId)

        <button type="submit" class="btn btn-danger">Delete</button> 
@Html.ActionLink("Cancel", "Index", new { resumeId = Model.ResumeId }, new { @class = "btn btn-default" })
    }
</div>
