@model FINAL.Models.Template_2.Languages

@{
    ViewBag.Title = "Language Details";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Language Details</h2>

<div>
    <h4>@Model.LanguageName</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.LanguageName)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.LanguageName)
        </dd>
    </dl>
</div>

<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.LanguageId }) |
    @Html.ActionLink("Back to List", "Index", new { resumeId = Model.ResumeId })
</p>
