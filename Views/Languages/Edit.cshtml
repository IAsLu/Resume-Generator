@model FINAL.Models.Template_2.Languages

@{
    ViewBag.Title = "Edit Language";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Edit Language</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(model => model.LanguageName)
        @Html.TextBoxFor(model => model.LanguageName, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.LanguageName)
    </div>

    @Html.HiddenFor(model => model.LanguageId)
    @Html.HiddenFor(model => model.ResumeId)

    <button type="submit" class="btn btn-primary">Save</button>
}
