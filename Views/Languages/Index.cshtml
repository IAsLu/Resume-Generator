@model IEnumerable<FINAL.Models.Template_2.Languages>

@{
    ViewBag.Title = "Languages";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Languages</h2>

<p>
    @Html.ActionLink("Create New Language", "Create", new { resumeId = ViewBag.ResumeId })
</p>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().LanguageName)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.LanguageName)</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.LanguageId }) |
                    @Html.ActionLink("Details", "Details", new { id = item.LanguageId }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.LanguageId })
                </td>
            </tr>
        }
    </tbody>
</table>
