@model IEnumerable<FINAL.Models.Resume>
@{
    ViewBag.Title = "Det";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="rule mt-4">
    <p>
        @Html.ActionLink("Create New", "Create", new { @class = "btn btn-primary" })
    </p>

    <table class="table table-bordered table-striped">
        <thead class="thead-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>LinkedIn</th>
                <th>GitHub</th>
                <th>Professional Summary</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                    <td>@Html.DisplayFor(modelItem => item.LinkedIn)</td>
                    <td>@Html.DisplayFor(modelItem => item.GitHub)</td>
                    <td>@Html.DisplayFor(modelItem => item.ProfessionalSummary)</td>
                    <td>
                        @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                        @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                        @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    body {
        background-image: url('https://wallpapercrafter.com/desktop1/615580-blank-notebook-pencil-pen-desk-wood-write-book.jpg');
        background-size: cover; /* Ensure the image covers the entire background */
        background-position: center; /* Center the image */
        background-repeat: no-repeat; /* Prevent repeating of the image */
    }

    .table th, .table td {
        text-align: center; /* Center-align text in table cells */
    }

    .btn-primary {
        margin-bottom: 10px; /* Space between button and table */
    }

    .rule {
        margin-top: 20px;
        background-color: rgba(255, 255, 255, 0.8); /* Optional: white background with slight opacity for readability */
        padding: 20px;
        border-radius: 8px; /* Optional: rounded corners for the container */
    }

    .table {
        margin-top: 20px;
    }
</style>
