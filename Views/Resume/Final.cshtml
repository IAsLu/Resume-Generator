@model FINAL.Models.ResumeDetailsViewModel
@{
    ViewBag.Title = "Final";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resume Details</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
            background-image: url('https://img.pikbest.com/wp/202344/white-seamless-texture-soft-mink-cotton-wool-background_9929452.jpg!sw800');
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            background-attachment: fixed;
        }

        /* Adjust padding-top to account for the fixed navbar */
        .resume-container {
            width: 90%;
            max-width: 800px;
            margin: 80px auto 20px auto; /* Top margin to push content below the fixed header */
            background-color: #fff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h1, h2, h3 {
            margin: 0 0 10px 0;
            font-weight: normal;
        }

        h1 {
            text-align: center;
            font-size: 2em;
            color: #333;
        }

        .contact-info {
            text-align: center;
            margin-bottom: 20px;
        }

            .contact-info p {
                margin: 5px 0;
                font-size: 1em;
            }

        .section {
            margin-bottom: 20px;
        }

            .section h2 {
                border-bottom: 2px solid #333;
                padding-bottom: 5px;
                margin-bottom: 10px;
                font-size: 1.5em;
                color: #333;
            }

        .job {
            margin-bottom: 20px;
        }

            .job h3 {
                margin: 0;
                font-size: 1.2em;
                color: #444;
            }

            .job .meta {
                font-size: 0.9em;
                color: #666;
            }

            .job ul {
                list-style-type: disc;
                margin: 10px 0 0 20px;
                padding: 0;
            }

            .job p, .job ul {
                margin: 5px 0;
            }

        .skills-list, .education-list {
            list-style-type: none;
            padding: 0;
        }

            .skills-list li, .education-list li {
                margin: 5px 0;
                font-size: 1em;
            }

            .skills-list li {
                display: inline-block;
                margin-right: 10px;
                padding: 5px 10px;
                background-color: #eee;
                border-radius: 5px;
            }

        .resume-actions {
            text-align: center;
            margin-top: 20px;
        }

            .resume-actions .btn {
                margin: 5px;
            }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/1.3.2/jspdf.min.js"></script>
    <script>
        //function preback() {
        //    window.history.forward();
        //} setTimeout("preback()", 0);
        //window.onunload = function () { null };

        function downloadPDF() {
            html2canvas(document.querySelector(".resume-container"), {
                useCORS: true
            }).then(canvas => {
                const imgData = canvas.toDataURL("image/png");
                const pdf = new jsPDF({
                    orientation: "p",
                    unit: "mm",
                    format: "a4"
                });
                pdf.addImage(imgData, "PNG", 10, 10, 190, 0);
                pdf.save("ResumeDetails.pdf");
            });
        }
    </script>
</head>
<body>
    <div class="resume-container">
        <h1>@Model.Resume.Name</h1>
        <div class="contact-info">
            <p>Email: @Model.Resume.Email</p>
            <p>Phone: @Model.Resume.Phone</p>
            <p>LinkedIn: @Model.Resume.LinkedIn</p>
            <p>GitHub: @Model.Resume.GitHub</p>
        </div>

        <div class="section">
            <h2>Professional Summary</h2>
            <p>@Model.Resume.ProfessionalSummary</p>
        </div>

        <div class="section">
            <h2>Work Experience</h2>
            @foreach (var work in Model.WorkExperiences)
            {
                <div class="job">
                    <h3>@work.JobTitle</h3>
                    <p class="meta">@work.Company, @work.Location | @work.Years yr</p>
                </div>
            }
        </div>

        <div class="section">
            <h2>Education</h2>
            <ul class="education-list">
                @foreach (var edu in Model.Educations)
                {
                    <li>@edu.Degree <span>@edu.Institution | @edu.GraduationYear</span></li>
                }
            </ul>
        </div>

        <div class="section">
            <h2>Skills</h2>
            <ul class="skills-list">
                @foreach (var skill in Model.Skills)
                {
                    <li>@skill.SkillName</li>
                }
            </ul>
        </div>

        <div class="section">
            <h2>Certifications</h2>
            <ul class="education-list">
                @foreach (var cert in Model.Certifications)
                {
                    <li>@cert.CertificationName <span>Issued by @cert.IssuedBy | @cert.Year</span></li>
                }
            </ul>
        </div>

        <div class="section">
            <h2>Projects</h2>
            @foreach (var project in Model.Projects)
            {
                <div class="job">
                    <h3>@project.ProjectName</h3>
                    <p>@project.ProjectDescription</p>
                </div>
            }
        </div>
    </div>

    <div class="resume-actions">
        @Html.ActionLink("Back to Resume List", "Index", "Resume", null, new { @class = "btn btn-secondary" })
        @Html.ActionLink("Edit Resume", "Edit", "Resume", new { Id = Model.Resume.Id }, new { @class = "btn btn-primary" })
        <button onclick="downloadPDF()" class="btn btn-success">Download PDF</button>
    </div>
</body>
</html>
