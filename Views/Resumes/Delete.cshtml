@model FINAL.Models.Template_2.Resumes

@{
    ViewBag.Title = "Delete Resume";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Delete Resume</h2>

<div>
    <h3>Are you sure you want to delete this resume?</h3>
    <div>
        <h4>Resume Details</h4>
        <dl class="dl-horizontal">
            <dt>Name:</dt>
            <dd>@Model.Name</dd>
            <dt>Email:</dt>
            <dd>@Model.Email</dd>
            <dt>Phone:</dt>
            <dd>@Model.Phone</dd>
            <dt>Address:</dt>
            <dd>@Model.Address</dd>
            <dt>Professional Summary:</dt>
            <dd>@Model.ProfessionalSummary</dd>
        </dl>
    </div>

    <div>
        @using (Html.BeginForm("Delete", "Resumes", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.ResumeId)
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a href="@Url.Action("Index", "Resumes")" class="btn btn-default">Cancel</a>
        }
    </div>
</div>
