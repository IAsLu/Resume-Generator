@{
    ViewBag.Title = "ViewTemplate";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<body>
    <div class="container">
        <div class="template-row">
            <div class="template-section">
                <h3>Template 1</h3>
                <br />
                <img id="thumbnail1" src="~/images/RESIMG.jpeg" class="change" alt="Template Image" style="width: 250px; height: 300px; cursor: pointer;" onclick="showFullImage('thumbnail1')" />
                <br />
                <a href="@Url.Action("Det", "Resume", new { id = 1 })" class="btn-details">Details</a> <!-- Adjust the Action and Controller names accordingly -->
            </div>

            <div class="template-section">
                <h3>Template 2</h3>
                <br />
                <img id="thumbnail2" src="~/images/Screenshot (224).png" class="change" alt="Template Image" style="width: 250px; height: 300px; cursor: pointer;" onclick="showFullImage('thumbnail2')" />
                <br />
                <a href="@Url.Action("Index", "Resumes", new { id = 2 })" class="btn-details">Details</a> <!-- Adjust the Action and Controller names accordingly -->
            </div>
        </div>

        <!-- The Modal -->
        <div id="myModal" class="modal" onclick="closeModal(event)">
            <span class="close" onclick="closeModal(event)">&times;</span>
            <img class="modal-content" id="fullImage">
        </div>
    </div>
</body>

<!-- Modal Styles -->
<style>
    body {
        background-image: url("https://images.unsplash.com/photo-1554120013-4ba50c1a1788?fm=jpg&q=60&w=3000&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxleHBsb3JlLWZlZWR8OHx8fGVufDB8fHx8fA%3D%3D");
        background-size: cover;
        background-position: center;
    }

    .change{
        border-radius:20px;
    }

    .container {
        position: relative;
        padding: 20px;
    }

    .template-row {
        display: flex;
        justify-content: flex-start; /* Align templates to the left */
        margin-top: 40px;
        gap: 20px; /* Adjust this value to control the distance between Template 1 and Template 2 */
    }

    .template-section {
        padding: 20px;
        text-align: center;
    }

    .btn-details {
        display: inline-block;
        padding: 10px 20px;
        margin-top: 10px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        font-size: 16px;
    }

        .btn-details:hover {
            background-color: white;
        }

    .modal {
        display: none;
        position: fixed;
        z-index: 1;
        padding-top: 100px;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0,0,0,0.9);
    }

    .modal-content {
        margin: auto;
        display: block;
        width: 80%;
        max-width: 700px;
    }

    .close {
        position: absolute;
        top: 15px;
        right: 35px;
        color: #fff;
        font-size: 40px;
        font-weight: bold;
        transition: 0.3s;
    }

        .close:hover,
        .close:focus {
            color: #bbb;
            text-decoration: none;
            cursor: pointer;
        }
</style>

<!-- Modal Script -->
<script>
    function showFullImage(thumbnailId) {
        var modal = document.getElementById("myModal");
        var fullImage = document.getElementById("fullImage");
        var thumbnail = document.getElementById(thumbnailId);

        fullImage.src = thumbnail.src;
        modal.style.display = "block";
    }

    function closeModal(event) {
        var modal = document.getElementById("myModal");
        if (event.target === modal) {
            modal.style.display = "none";
        }
    }
</script>
