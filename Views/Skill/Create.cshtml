@model FINAL.Models.Skill
@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

@*<h2>Create Skill</h2>*@

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4 style="margin-top:20px;">Skill</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @Html.HiddenFor(model => model.ResumeId, new { Value = ViewBag.ResumeId })

        <div class="form-group">
            @Html.LabelFor(model => model.SkillName, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextAreaFor(model => model.SkillName, new { @class = "form-control large-text-area", style = "border-radius: 10px;" })
                @Html.ValidationMessageFor(model => model.SkillName, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="button" onclick="history.back()" class="btn btn-secondary">Back</button>
                <input type="submit" value="Next" class="btn btn-primary"  />
            </div>
        </div>
    </div>
}

<style>
    .large-text-area {
        width: 100%;
        height: 200px; /* Adjust the height as needed */
        border-radius: 10px; /* Curved borders */
        padding: 10px; /* Optional: Add some padding inside the text area */
        box-sizing: border-box; /* Ensure padding and border are included in the element's total width and height */
    }

    .form-group {
        margin-bottom: 20px; /* Space between form elements */
    }

    body {
        background-image: url('https://img.pikbest.com/wp/202344/white-seamless-texture-soft-mink-cotton-wool-background_9929452.jpg!sw800');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        background-attachment: fixed;
    }
</style>



