@model FINAL.Models.Template_2.WorkExperiences

@{
    ViewBag.Title = "Edit Work Experience";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    body {
        background-image: url('https://img.pikbest.com/wp/202344/white-seamless-texture-soft-mink-cotton-wool-background_9929452.jpg!sw800');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    .form-group {
        margin-bottom: 25px; /* Add spacing between fields */
    }

    h2 {
        
        margin-bottom: 30px; /* Add spacing below the heading */
        color: #333;
    }

    .form-actions {
        margin-top: 20px;
        
    }

    label {
        font-weight: bold;
    }

    .form-control {
        border-radius: 5px; /* Add slight border radius for smoother appearance */
    }

    button {
        margin-right: 10px;
    }
</style>

<h2 style="margin-top:7px;">Edit Work Experience</h2>

@using (Html.BeginForm("Edit", "WorkExperiences", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(model => model.ExperienceId)
    @Html.HiddenFor(model => model.ResumeId)

    <div class="form-group">
        @Html.LabelFor(model => model.JobTitle)
        @Html.TextBoxFor(model => model.JobTitle, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.JobTitle)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.CompanyName)
        @Html.TextBoxFor(model => model.CompanyName, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.CompanyName)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.City)
        @Html.TextBoxFor(model => model.City, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.City)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.State)
        @Html.TextBoxFor(model => model.State, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.State)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.StartDate)
        @Html.TextBoxFor(model => model.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.StartDate)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.EndDate)
        @Html.TextBoxFor(model => model.EndDate, "{0:yyyy-MM-dd}", new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.EndDate)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Responsibilities)
        @Html.TextAreaFor(model => model.Responsibilities, new { @class = "form-control", rows = 4 }) <!-- Increased rows for better display -->
        @Html.ValidationMessageFor(model => model.Responsibilities)
    </div>

    <div class="form-actions">
        <button type="button" onclick="history.back()" class="btn btn-secondary">Back</button>
        <button type="submit" class="btn btn-primary">Next</button>
    </div>
}
